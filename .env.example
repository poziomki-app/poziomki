DATABASE_URL=postgres://loco:loco@localhost:5432/poziomki-backend_development
JWT_SECRET=change-me-in-production

# Garage S3 (used when NODE_ENV=production)
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_BUCKET=poziomki-uploads
# GARAGE_S3_ACCESS_KEY=
# GARAGE_S3_SECRET_KEY=
GARAGE_S3_REGION=us-east-1
GARAGE_S3_URL_EXPIRY=3600
# GARAGE_S3_PUBLIC_URL=https://cdn.poziomki.app

# Caddy upload proxy
CADDY_API_UPSTREAM=host.docker.internal:5150
CADDY_GARAGE_S3_UPSTREAM=garage.local:3900

ANDROID_HOME=/path/to/android/sdk
JAVA_HOME=/usr/lib/jvm/java-21-openjdk
