DATABASE_URL=postgres://poziomki:poziomki@localhost:5432/poziomki-backend_development
JWT_SECRET=change-me-in-production

# Diesel pool (app-side; useful with PgDog in prod)
# 0 disables a timeout (not recommended for wait timeout).
# DB_POOL_MAX_SIZE=10
# DB_POOL_WAIT_TIMEOUT_MS=3000
# DB_POOL_CREATE_TIMEOUT_MS=5000
# DB_POOL_RECYCLE_TIMEOUT_MS=5000
# Garage S3
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_BUCKET=poziomki-uploads
# GARAGE_S3_ACCESS_KEY=
# GARAGE_S3_SECRET_KEY=
GARAGE_S3_REGION=garage
GARAGE_S3_URL_EXPIRY=3600
# GARAGE_S3_PUBLIC_URL=https://cdn.poziomki.app

# Matrix chat bootstrap
# MATRIX_HOMESERVER_URL=http://localhost:6167
# MATRIX_HOMESERVER_PUBLIC_URL=https://chat.poziomki.app
# MATRIX_PASSWORD_PEPPER=replace-with-strong-random-value
# MATRIX_REGISTRATION_TOKEN=replace-with-homeserver-registration-token
# PUSH_GATEWAY_TOKEN=replace-with-strong-random-value
# PUSH_GATEWAY_ALLOWED_HOSTS=ntfy.poziomki.app
# PUSH_GATEWAY_URL=https://rs.poziomki.app/_matrix/push/v1/notify?token=${PUSH_GATEWAY_TOKEN}

# SMTP (OTP emails)
SMTP_ENABLE=false
SMTP_HOST=stalwart
# SMTP_TLS_NAME: hostname for TLS cert validation (when SMTP_HOST is a Docker
# service name like "stalwart" but the cert is issued for a real domain).
# SMTP_TLS_NAME=mail.poziomki.app
SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM=noreply@poziomki.app

# Caddy upload proxy
CADDY_API_UPSTREAM=host.docker.internal:5150
CADDY_GARAGE_S3_UPSTREAM=garage.local:3900
CADDY_IMGPROXY_UPSTREAM=imgproxy:3080

# Image proxy
IMGPROXY_HMAC_KEY=           # base64-encoded 32-byte key (generate: openssl rand -base64 32)
# IMGPROXY_CACHE_BYTES=67108864    # 64MB default
# IMGPROXY_MAX_CONCURRENT=2        # max concurrent resize ops
IMGPROXY_PURGE_SECRET=       # shared secret for purge endpoint (generate: openssl rand -hex 32)
IMGPROXY_BASE_URL=           # e.g. https://rs.poziomki.app (empty = relative)
IMGPROXY_URL_EXPIRY_SECS=120
IMGPROXY_ALLOWED_PREFIX=uploads/
# IMGPROXY_BIND_ADDRESS=127.0.0.1  # default; compose overrides to 0.0.0.0 for Docker
# IMGPROXY_CLOCK_SKEW_SECS=5       # grace window for clock drift
# IMGPROXY_S3_ACCESS_KEY=          # dedicated read-only S3 key for imgproxy (falls back to GARAGE_S3_ACCESS_KEY)
# IMGPROXY_S3_SECRET_KEY=          # dedicated read-only S3 secret for imgproxy

# PgDog (prod compose defaults; optional overrides)
# PGDOG_POOL_SIZE=20
# API_DB_POOL_MAX_SIZE=16
# WORKER_DB_POOL_MAX_SIZE=8

# Beszel (ops profile)
# BESZEL_APP_URL=https://ops.poziomki.app
# BESZEL_AGENT_HUB_URL=http://127.0.0.1:8090
# BESZEL_AGENT_LISTEN=/beszel_socket/beszel.sock
# BESZEL_AGENT_TOKEN=generated-in-beszel-hub
# BESZEL_AGENT_KEY=generated-in-beszel-hub

ANDROID_HOME=/path/to/android/sdk
JAVA_HOME=/usr/lib/jvm/java-21-openjdk
