# Postgres
POSTGRES_USER=poziomki
POSTGRES_PASSWORD=
POSTGRES_DB=poziomki

# API / Worker
JWT_SECRET=
SERVER_HOST=https://rs.poziomki.app
ALLOWED_EMAIL_DOMAIN=*

# Garage S3
GARAGE_S3_ACCESS_KEY=
GARAGE_S3_SECRET_KEY=
GARAGE_S3_BUCKET=poziomki-uploads
GARAGE_S3_REGION=garage
GARAGE_S3_URL_EXPIRY=3600
GARAGE_S3_PUBLIC_URL=https://cdn.poziomki.app

# imgproxy
IMGPROXY_HMAC_KEY=
IMGPROXY_HMAC_SALT=
IMGPROXY_BASE_URL=
IMGPROXY_URL_EXPIRY_SECS=3600
IMGPROXY_SOURCE_URL_ENCRYPTION_KEY=

# Matrix (tuwunel)
MATRIX_SERVER_NAME=chat.poziomki.app
MATRIX_HOMESERVER_URL=http://tuwunel:6167
MATRIX_HOMESERVER_PUBLIC_URL=
MATRIX_PASSWORD_PEPPER=
MATRIX_REGISTRATION_TOKEN=

# Push notifications
PUSH_GATEWAY_TOKEN=
PUSH_GATEWAY_ALLOWED_HOSTS=ntfy.poziomki.app

# SMTP (stalwart)
SMTP_ENABLE=true
SMTP_HOST=stalwart
SMTP_PORT=587
SMTP_USER=admin
SMTP_PASSWORD=
